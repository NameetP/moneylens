{
  "$id": "bank-statement-uae",
  "description": "UAE credit card statement — extract account info and transactions",
  "type": "object",
  "properties": {
    "bank": {
      "type": "string",
      "description": "Issuing bank name (e.g. Emirates NBD, ADCB, FAB)"
    },
    "card_type": {
      "type": "string",
      "description": "Card product name (e.g. Visa Platinum, Mastercard Titanium)"
    },
    "card_number_last4": {
      "type": "string",
      "pattern": "\\d{4}",
      "description": "Last 4 digits of card number"
    },
    "statement_period": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date", "description": "Statement start date" },
        "to": { "type": "string", "format": "date", "description": "Statement end date" }
      }
    },
    "outstanding_balance": {
      "type": "number",
      "description": "Total outstanding balance due in AED"
    },
    "minimum_payment": {
      "type": "number",
      "description": "Minimum payment due in AED"
    },
    "credit_limit": {
      "type": "number",
      "description": "Total credit limit in AED"
    },
    "interest_rate_monthly": {
      "type": "number",
      "description": "Monthly interest/finance charge rate as percentage (e.g. 3.49)"
    },
    "payment_due_date": {
      "type": "string",
      "format": "date",
      "description": "Payment due date"
    },
    "total_spend": {
      "type": "number",
      "description": "Total spending/debits this period in AED"
    },
    "total_payments": {
      "type": "number",
      "description": "Total payments/credits received this period in AED"
    },
    "transactions": {
      "type": "array",
      "description": "Individual transaction line items",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date", "description": "Transaction date" },
          "description": { "type": "string", "description": "Merchant name or transaction description" },
          "amount": { "type": "number", "description": "Transaction amount in AED (positive = debit)" },
          "type": { "enum": ["debit", "credit", "payment", "fee", "interest"], "description": "Transaction type" }
        }
      }
    },
    "fees": {
      "type": "array",
      "description": "Fees and charges",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "amount": { "type": "number" }
        }
      }
    }
  }
}
